{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile NBM Source",
      "type": "shell",
      "command": "nbm template -o gen && latexmk -synctex=1 -interaction=nonstopmode -file-line-error -pdf -outdir=out -bibtex gen/template.tex",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
