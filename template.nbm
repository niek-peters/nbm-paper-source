  \toprule
  \textbf{Algorithm} & \textbf{Implementation} & \textbf{\LaTeX\ output} \\
  \midrule

  Euclidean & See Section~\ref{section:euclidean-case-study} \\
  \midrule
  
 \makecell{Extended\\Euclidean} & \codecell{ExtendedEuclideanSource} & \makecell{
    <<<
#[intext]
egcd : N x N -> Z+ x Z x Z
egcd(a, b) := {
    (a, 1, 0)                       if b = 0
    (g, y, x - floor (a / b) * y)   otherwise
} where a >= b, (g, x, y) := egcd(b, a mod b)
    >>>
  } \\ 
  \midrule
  
 \makecell{Modular\\Inverse} & \codecell{ModInvSource} & \makecell{
    <<<
#[intext]
modInv : N x Z+ -> Z+
modInv(a, m) := x mod m
where (g, x, y) := egcd(a, m), g = 1
    >>>
  } \\ 
  \midrule
  
 \makecell{Fast\\Exponentiation} & \codecell{FastExpSource} & \makecell{
    <<<
#[intext]
fastExp : R x N -> R
fastExp(a, n) := {
    1       if n = 0
    r       if 2 | n
    a * r   otherwise
} where r := fastExp(a ^ 2, floor (n / 2))
    >>>
  } \\ 
  \midrule
  
 \makecell{Prime\\Testing} & \codecell{PrimeTestSource} & \makecell{
    <<<
#[intext]
isPrime : N -> B
isPrime(n) := {
    False                           if n < 2
    check(n, 2, floor (sqrt n))     otherwise
}

check : N x N x N -> B
check(n, t, l) := {
    True                if t > l
    False               if t | n
    check(n, t + 1, l)  otherwise
}
    >>>
  } \\ 
  \midrule
  
 \makecell{Integer\\Square\\Root} & \codecell{IntSqrtSource} & \makecell{
    <<<
#[intext]
isqrt : Z+ -> Z+
isqrt(n) := newtIter(n, n)

newtIter : Z+ x Z+ -> Z+
newtIter(n, x) := {
    newtIter(n, y)  if y < x
    x               otherwise
} where y := floor ((x + floor (n / x)) / 2)
    >>>
  } \\ 

