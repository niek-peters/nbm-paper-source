 \makecell{Extended\\Euclidean} & \codecell{ExtendedEuclideanSource} & \makecell{
    <<<
#[intext]
egcd : N x N -> Z+ x Z x Z
egcd(a, b) := {
    (a, 1, 0)                       if b = 0
    (g, y, x - floor (a / b) * y)   otherwise
} where a >= b, (g, x, y) := egcd(b, a mod b)
    >>>
  } \\ 
