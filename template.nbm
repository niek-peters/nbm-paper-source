\section{Mathematical notation and Haskell syntax}
\label{appendix:notation}
\begin{xltabular}{\textwidth}{l X}
  \toprule
  \textbf{Notation} & \textbf{Meaning} \\
  \midrule

  \multicolumn{2}{l}{\textbf{Sets and constructs}} \\
  \midrule
  $\mathbb{N}$ & Set of all natural numbers. $\mathbb{N} = \{0, 1, 2, ...\}$\\
  $\mathbb{Z}$ & Set of all integers. $\mathbb{Z} = \{..., -2, -1, 0, 1, 2, ...\}$\\
  $\mathbb{Z}^+$ & Set of all positive integers. $\mathbb{Z}^+ = \{1, 2, ...\}$\\
  $\mathbb{Q}$ & Set of all rational numbers\\
  $\mathbb{R}$ & Set of all real numbers\\
  $\mathbb{B}$ & Set of all booleans~\cite[p.~73]{cortadella2002logic}. $\mathbb{B} = \{True, False\}$\footnote{Grimaldi~\cite[p.~49]{grimaldi2004discrete} shows using $true$ and $false$ for boolean values. The author decided to capitalise these values to make them stand out from lowercase `keywords' in the mathematical notation output (e.g. `if', `otherwise' and `where').}\\
  $\mathbb{N} \times \mathbb{Z} \times \mathbb{Z}^+$ & Set of all ordered tuples of all natural numbers, integers and positive integers. E.g. (0, -1, 1)\\
  \midrule

  \multicolumn{2}{l}{\textbf{Functions and constants}} \\
  \midrule
  \makecell{Define \texttt{<signature>} by \\ \texttt{<implementation>} \\ where \texttt{<constraints>}} & Function or constant definition~\cite[p.~135]{judson2023abstract}, \cite[p.~254]{grimaldi2004discrete}. \\
  $f : \mathbb{N} \times \mathbb{N} \to \mathbb{N}$ & Function or constant signature. Here: function f, which takes two natural numbers, maps to a natural number. \\
  $f(a, b) = a + b + c$ & Function or constant implementation. Here: function f adds two numbers and adds some value $c$ to the result. \\
  $a \geq b, a > 50 \text{ and } c = ab$ & Function or constant constraints. Here: $a$ is greater than or equal to $b$, $a$ is greater than 50 and $c$ is equal to $a$ times $b$. \\
  \makecell{$min(a, b) = \begin{cases}
  a & \text{if } a < b \\
  b & \text{otherwise}
  \end{cases}$} & Piecewise function implementation~\cite[p.~5]{zhu2010mathematical}. Here: return $a$ when $a$ is less than $b$, otherwise return $b$. \\
  $f(1, 2)$ & Function call. Here: call $f$ with $a = 1$ and $b = 2$. \\
  \midrule
  
  \multicolumn{2}{l}{\textbf{Operations}} \\
  \midrule
  $a + b$ & Addition of $a$ and $b$ \\
  $a - b$ & Difference of $a$ and $b$ \\
  $-a$ & Unary negation of $a$ \\
  $a \cdot b$ & Product of $a$ and $b$ \\
  $\frac{a}{b}$ & Fraction of $a$ over $b$ \\
  $a^b$ & $a$ to the $b_{th}$ power \\
  $\sqrt{a}$ & Square root of $a$ \\
  $a \bmod b$ & Remainder of $a$ divided by $b$ \\
  $\lfloor a \rfloor$ & Floor of $a$. Closest integer less than or equal to $a$ \\
  $a = b$ & $True$ if $a$ and $b$ are equal \\
  $a \neq b$ & $True$ if $a$ and $b$ are not equal \\
  $a < b$ & $True$ if $a$ is strictly less than $b$ \\
  $a > b$ & $True$ if $a$ is strictly greater than $b$ \\
  $a \leq b$ & $True$ if $a$ is less than or equal to $b$ \\
  $a \geq b$ & $True$ if $a$ is greater than or equal to $b$ \\
  $a \mid b$ & $True$ if $a$ divides $b$ \\
  $p \land q$ & $True$ if $p$ and $q$ are both $True$ \\
  $p \lor q$ & $True$ if $p$ or $q$ is $True$ \\
  $\neg p$ & $True$ if $p$ is $False$ \\
  \bottomrule
  \caption{Mathematical notation. Any notation without citation is taken from \cite[pp.~ii--iii]{grimaldi2004discrete} and \cite[pp.~333--335]{judson2023abstract}.}
  \label{table:math-notation}
\end{xltabular}

\begin{xltabular}{\textwidth}{l X X}
  \toprule
  \textbf{Notation} & \textbf{Haskell translation} & \textbf{Notes} \\
  \midrule

  \multicolumn{3}{l}{\textbf{Sets and constructs}} \\
  \midrule
  $\mathbb{N}$ & \texttt{Natural} \\
  $\mathbb{Z}$ & \texttt{Integer} \\
  $\mathbb{Z}^+$ & \texttt{Positive} & Custom Positive type in the Prelude, holding a Natural with an additional $\neq 0$ constraint check on creation\\
  $\mathbb{Q}$ & \texttt{Rational} & This is an alias for "Ratio Integer", meaning any fractions using Naturals, which are "Ratio Natural", will need to have their operands be converted to Integers first. \\
  $\mathbb{R}$ & \texttt{Double} & Unlike the type translations before, this one is not arbitrary precision, meaning some accuracy is lost. This appears to be an unavoidable compromise. As we make fractions return rational numbers, however, this type is avoided as much as possible\\
  $\mathbb{B}$ & \texttt{Bool} \\
  $\mathbb{N} \times \mathbb{Z} \times \mathbb{Z}^+$ & \makecell{for function arguments:\\\texttt{Natural -> Integer -> Natural} \\ \\ for function return types:\\\texttt{(Natural, Integer, Natural)}} & Here the generated Haskell differs depending on if the tuple is for a function's arguments (expressed as individual arguments) or a returned tuple (expressed as a single composite value). We could make both use the composite value approach, but this would result in less idiomatic Haskell, always using tuples for any functions with multiple arguments\\
  \midrule

  \multicolumn{3}{l}{\textbf{Functions and constants}} \\
  \midrule
  \makecell{Define \texttt{<signature>} by \\ \texttt{<implementation>} \\ where \texttt{<constraints>}} & See Section~\ref{section:mapping-to-haskell} \\
  \midrule
  
  \multicolumn{3}{l}{\textbf{Operations} (operate only on number types unless stated otherwise)} \\
  \midrule
  $a + b$ & \texttt{a + b} & Widens operands and result to widest type of $a$ and $b$ \\
  $a - b$ & \texttt{a - b} & Widens operands and result to widest type of $a$ and $b$, at least Integer (to allow negative results)\\
  $-a$ & \texttt{-a} & Widens operand and result to at least Integer (to allow negative results) \\
  $a \cdot b$ & \texttt{a * b} & Widens operands and result to widest type of $a$ and $b$ \\
  $\frac{a}{b}$ & \texttt{a \% b (or a / b)} & Widens operands to widest type of $a$ and $b$, at least Integer. Returns Rational (if neither operand is Double) or Double (otherwise). Translates to \texttt{\%} by default and to \texttt{/} if numerator or denominator are already fractions. Crashes if $b = 0$ \\
  $a^b$ & \texttt{a \^{} b (or a \^{}\^{} b or a ** b)} & If type of $b$ is (at most) Natural, widens b to Natural (Haskell needs 0 to exist), translates to \texttt{\^{}} and returns type of $a$. If type of $b$ is Integer, widens $a$ and result to at least Rational and translates to \texttt{\^{}\^{}}. Otherwise widens operands to Double, translates to \texttt{**} and returns Double \\
  $\sqrt{a}$ & \texttt{sqrt a} & Widens operand to Double. Returns Double \\  
  $a \bmod b$ & \texttt{a \`{}mod\`{} b} & Widens operands and result to at least Natural (Haskell needs 0 to exist) and narrows to at most Integer. Must have $b$ be a positive integer \\
  $\lfloor a \rfloor$ & \texttt{floor} a & Only defined when $a$ is Rational or Double. Returns Integer \\
  $a = b$ & \texttt{a = b (or a == b)} & Translates to \texttt{=} for declarations and \texttt{==} for equality checks. Equality check is defined for all operand types, widens operands to smallest common supertype of $a$ and $b$, then returns Bool \\
  $a \neq b$ & \texttt{a /= b} & Defined for all operand types. Widens operands to smallest common supertype of $a$ and $b$. Returns Bool \\
  $a < b$ & \texttt{a < b} & Widens operands and result to widest type of $a$ and $b$. Returns Bool \\
  $a > b$ & \texttt{a > b} & Widens operands and result to widest type of $a$ and $b$. Returns Bool \\
  $a \leq b$ & \texttt{a <= b} & Widens operands and result to widest type of $a$ and $b$. Returns Bool \\
  $a \geq b$ & \texttt{a >= b} & Widens operands and result to widest type of $a$ and $b$. Returns Bool \\
  $a \mid b$ & \texttt{b \`{}mod\`{} a == 0} & Widens operands to at least Natural (Haskell needs 0 to exist) and narrows to at most Integer. Returns Bool. Crashes if $a = 0$ \\
  $p \land q$ & \texttt{p \&\& q} & Defined only for operands of type Bool. Returns Bool \\
  $p \lor q$ & \texttt{p || q} & Defined only for operands of type Bool. Returns Bool \\
  $\neg p$ & \texttt{not p} & Defined only for operand of type Bool. Returns Bool \\

  \bottomrule
  \caption{Math to Haskell translation}
  \label{table:math-haskell-translation}
\end{xltabular}

\section{Algorithms implemented in NBM}
\label{appendix:algorithms-nbm}
\begin{SaveVerbatim}{ExtendedEuclideanSource} 
egcd : N x N -> Z+ x Z x Z
egcd(a, b) := {
    (a, 1, 0)                       if b = 0
    (g, y, x - floor (a / b) * y)   otherwise
} where a >= b, (g, x, y) := egcd(b, a mod b)
\end{SaveVerbatim}
\begin{SaveVerbatim}{ModInvSource} 
modInv : N x Z+ -> Z+
modInv(a, m) := x mod m
where (g, x, y) := egcd(a, m), g = 1
\end{SaveVerbatim}
\begin{SaveVerbatim}{FastExpSource} 
fastExp : R x N -> R
fastExp(a, n) := {
    1       if n = 0
    r       if 2 | n
    a * r   otherwise
} where r := fastExp(a ^ 2, floor (n / 2))
\end{SaveVerbatim}
\begin{SaveVerbatim}{PrimeTestSource} 
isPrime : N -> B
isPrime(n) := {
    False                           if n < 2
    check(n, 2, floor (sqrt n))     otherwise
}

check : N x N x N -> B
check(n, t, l) := {
    True                if t > l
    False               if t | n
    check(n, t + 1, l)  otherwise
}
\end{SaveVerbatim}
\begin{SaveVerbatim}{IntSqrtSource} 
isqrt : Z+ -> Z+
isqrt(n) := newtIter(n, n)

newtIter : Z+ x Z+ -> Z+
newtIter(n, x) := {
    newtIter(n, y)  if y < x
    x               otherwise
} where y := floor ((x + floor (n / x)) / 2)
\end{SaveVerbatim}


